-- Status update
local function updateStatus()
    if comboTarget then
        TargetVal.Text         = comboTarget.name
        local rebirthAt        = comboTarget.req * threshold
        ReqLabel.Text          = "Target req: " .. formatNum(comboTarget.req)
        RebirthTargetLabel.Text = "Rebirth at: " .. formatNum(rebirthAt)
        WarnLabel.Text         = getAura() >= comboTarget.req * threshold and "⚠ Sedia untuk rebirth!" or ""
    else
        TargetVal.Text          = "—"
        ReqLabel.Text           = "Target req: —"
        RebirthTargetLabel.Text = "Rebirth at: —"
        WarnLabel.Text          = ""
    end
end

-- Popup logic
local function refreshPopupItems()
    for i, item in ipairs(popupItems) do
        local isSel     = selectedInPopup == i
        local isCurrent = comboTarget and comboTarget.name == item.area.name
        item.frame.BackgroundTransparency = isSel and 0 or 1
        item.frame.BackgroundColor3 = isSel and Color3.fromRGB(50,35,80) or Color3.fromRGB(25,20,38)
        item.dot.BackgroundColor3 = isSel and PURPLE or DIM
        item.nameLbl.TextColor3 = isSel and WHITE or Color3.fromRGB(180,175,200)
        item.checkLbl.Text = isCurrent and "✓" or ""
    end
end

local function openPopup()
    selectedInPopup = nil
    if comboTarget then
        for i,a in ipairs(areas) do
            if a.name == comboTarget.name then selectedInPopup = i; break end
        end
    end
    refreshPopupItems()
    Backdrop.Visible = true
    Popup.Visible = true
end

local function closePopup()
    Backdrop.Visible = false
    Popup.Visible = false
    selectedInPopup = nil
end

for i, item in ipairs(popupItems) do
    item.hitbox.MouseButton1Click:Connect(function()
        selectedInPopup = i
        refreshPopupItems()
    end)
end

CancelBtn.MouseButton1Click:Connect(closePopup)
Backdrop.MouseButton1Click:Connect(closePopup)
