local kRebUnitList = {}
for g = 4, 601 do
    local lbl = getSuffix(g)
    if lbl:sub(1,1) ~= "e" then
        table.insert(kRebUnitList, {g, lbl})
    end
end

local function findUnitIdx(label)
    for i, u in ipairs(kRebUnitList) do
        if u[2] == label then return i end
    end
    return 1
end

local function normalizeTarget(rawVal, rawUnit)
    local baseGroup = 4
    for _, u in ipairs(kRebUnitList) do
        if u[2] == rawUnit then baseGroup = u[1]; break end
    end
    local val = rawVal
    local grp = baseGroup
    while val >= 1000 and grp < 601 do
        val = val / 1000; grp = grp + 1
        while grp <= 601 and getSuffix(grp):sub(1,1) == "e" do grp = grp + 1 end
    end
    while val < 1 and grp > 4 do
        val = val * 1000; grp = grp - 1
        while grp >= 4 and getSuffix(grp):sub(1,1) == "e" do grp = grp - 1 end
    end
    val = math.floor(val * 100 + 0.5) / 100
    return val, getSuffix(grp), grp
end

