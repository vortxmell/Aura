-- ─── Server Hop Function ──────────────────────────────────────────────────────
local TeleportService = game:GetService("TeleportService")  -- remove line 1458 duplicate lepas ni
local placeId = game.PlaceId                                -- same, remove duplicate

local function hopToLeastPopulated(reason)
    if kothHopping then return end
    kothHopping = true
    kAutoStatus.Text = "🔄 Hopping... (" .. (reason or "?") .. ")"
    kAutoStatus.TextColor3 = WARN

    task.spawn(function()
        local currentJobId = game.JobId
        local bestServer = nil
        local bestCount = math.huge
        local cursor = ""

        for page = 1, 3 do
            local url = string.format(
                "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100",
                placeId
            )
            if cursor ~= "" then url = url .. "&cursor=" .. cursor end

            local ok2, result = pcall(function() return game:HttpGet(url) end)
            if not ok2 then break end

            local ok3, data = pcall(function()
                return game:GetService("HttpService"):JSONDecode(result)
            end)
            if not ok3 or not data or not data.data then break end

            for _, server in ipairs(data.data) do
                if server.id ~= currentJobId and server.playing ~= nil then
                    if server.playing < bestCount then
                        bestCount = server.playing
                        bestServer = server
                    end
                end
            end

            if data.nextPageCursor and data.nextPageCursor ~= "" then
                cursor = data.nextPageCursor
            else
                break
            end
        end

        if bestServer then
            kAutoStatus.Text = string.format("🚀 Hopping → %d player(s)", bestCount)
            task.wait(1)
            pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, bestServer.id, player)
            end)
        else
            kAutoStatus.Text = "❌ No server found"
            kAutoStatus.TextColor3 = RED
            task.wait(3)
            kothHopping = false
        end
    end)
end

