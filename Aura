-- Respawn
player.CharacterAdded:Connect(function()
    task.wait(3)
    if autoTraining or autoCombo then
        local best = getBestArea(getAura())
        if best then
            teleport(best.pos)
            currentArea = best.name
            StatusLabel.Text = "Area: " .. best.name
        end
    end
end)

-- Auto Training loop — bebas ikut aura, tak kena affect oleh combo
task.spawn(function()
    while true do
        if autoTraining or autoCombo then
            local aura = getAura()
            local best = getBestArea(aura)
            if best then
                if best.name ~= currentArea then
                    currentArea = best.name
                    teleport(best.pos)
                    StatusLabel.Text = "Area: " .. best.name
                end
            else
                StatusLabel.Text = "Area: Belum cukup aura"
            end
            updateStatus()
        end
        task.wait(5)
    end
end)

-- Auto Rebirth loop
task.spawn(function()
    while true do
        if autoTraining or autoCombo then
            RequestRebirth:InvokeServer()
            rebirthCount += 1
            RebirthLabel.Text = "Rebirths: " .. rebirthCount
            task.wait(0.1)
        else
            task.wait(0.1)
        end
    end
end)

-- Combo loop — rebirth ikut target, auto advance lepas rebirth
task.spawn(function()
    while true do
        if autoCombo and comboTarget then
            local aura      = getAura()
            local rebirthAt = comboTarget.req * threshold

            if aura >= rebirthAt then
                RequestRebirth:InvokeServer()
                rebirthCount += 1
                RebirthLabel.Text = "Rebirths: " .. rebirthCount
                task.wait(2)
               currentArea = nil

                -- Auto advance target ke next area
                local curIdx = getAreaIndex(comboTarget)
                if curIdx < #areas then
                    comboTarget = areas[curIdx + 1]
                else
                    -- Max area, kekal Fallen Star, rebirth unlimited
                end
                updateStatus()
            end
        end
        task.wait(1)
    end
end)

-- Init default target = next area dari aura semasa
local function initDefaultTarget()
    local next = getNextArea(getAura())
    comboTarget = next or areas[#areas]
    updateStatus()
end

initDefaultTarget()
