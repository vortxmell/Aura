-- ─── Toggle helper ───────────────────────────────────────────────────────────
local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad)

local function setToggle(pill, dot, stroke, on)
    if on then
        TweenService:Create(pill, tweenInfo, {BackgroundColor3 = Color3.fromRGB(110, 70, 200)}):Play()
        TweenService:Create(dot,  tweenInfo, {Position = UDim2.new(0, 16, 0.5, -5), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        TweenService:Create(stroke, tweenInfo, {Color = Color3.fromRGB(110, 70, 200)}):Play()
    else
        TweenService:Create(pill, tweenInfo, {BackgroundColor3 = Color3.fromRGB(40, 35, 55)}):Play()
        TweenService:Create(dot,  tweenInfo, {Position = UDim2.new(0, 2, 0.5, -5), BackgroundColor3 = Color3.fromRGB(100, 90, 130)}):Play()
        TweenService:Create(stroke, tweenInfo, {Color = Color3.fromRGB(60, 45, 90)}):Play()
    end
end

-- ─── Combo status update ─────────────────────────────────────────────────────
local function updateComboStatus()
    local aura = getAura()
    local next = getNextArea(aura)
    if next then
        NextAreaLabel.Text  = "Next: " .. next.name
        ReqLabel.Text       = "Req: " .. formatNum(next.req)
        RebirthAtLabel.Text = "Rebirth at: " .. formatNum(next.req * threshold)
    else
        NextAreaLabel.Text  = "Next: Max area!"
        ReqLabel.Text       = "Req: —"
        RebirthAtLabel.Text = "Rebirth at: 1000 aura"
    end
end

-- ─── Threshold buttons ───────────────────────────────────────────────────────
MinusBtn.MouseButton1Click:Connect(function()
    if threshold > 1 then
        threshold = threshold - 1
        ThreshValue.Text = threshold .. "x"
        updateComboStatus()
    end
end)

PlusBtn.MouseButton1Click:Connect(function()
    if threshold < 20 then
        threshold = threshold + 1
        ThreshValue.Text = threshold .. "x"
        updateComboStatus()
    end
end)

-- ─── Respawn handler ─────────────────────────────────────────────────────────
player.CharacterAdded:Connect(function()
    task.wait(3)
    if autoTraining or autoCombo then
        local best = getBestArea(getAura())
        if best then
            teleport(best.pos)
            currentArea = best.name
            StatusLabel.Text = "Area: " .. best.name
        end
    end
end)

-- ─── Auto Training loop ──────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoTraining or autoCombo then
            local aura = getAura()
            local best = getBestArea(aura)
            if best then
                if best.name ~= currentArea then
                    currentArea = best.name
                    teleport(best.pos)
                    StatusLabel.Text = "Area: " .. best.name
                end
            else
                StatusLabel.Text = "Area: Belum cukup aura"
            end
            updateComboStatus()
        end
        task.wait(5)
    end
end)

-- ─── Auto Rebirth loop ───────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoRebirth then
            RequestRebirth:InvokeServer()
            rebirthCount += 1
            RebirthLabel.Text = "Rebirths: " .. rebirthCount
            task.wait(0.1)
        else
            task.wait(0.1)
        end
    end
end)

-- ─── Combo loop ──────────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoCombo then
            local aura = getAura()
            local next = getNextArea(aura)
            local shouldRebirth = false
            if next then
                if aura >= next.req * threshold then shouldRebirth = true end
            else
                if aura >= 1000 then shouldRebirth = true end
            end
            if shouldRebirth then
                RequestRebirth:InvokeServer()
                rebirthCount += 1
                RebirthLabel.Text = "Rebirths: " .. rebirthCount
                task.wait(2)
                currentArea = nil
                updateComboStatus()
            end
        end
        task.wait(1)
    end
end)

