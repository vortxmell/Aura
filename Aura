-- LOOPS
-- ============================================================
task.spawn(function()
    while true do updateStatus(); task.wait(2) end
end)

task.spawn(function()
    while true do
        if (autoTraining or autoCombo) and not isRebirthing then
            local aura = getAura()
            local best = getBestArea(aura)
            if best and best.name ~= currentArea then
                currentArea = best.name; teleport(best.pos)
            end
        end
        task.wait(5)
    end
end)

task.spawn(function()
    while true do
        if autoRebirth and not isRebirthing then
            if RequestRebirth then RequestRebirth:InvokeServer() end
            rebirthCount = rebirthCount + 1
            RebirthLabel.Text = "Rebirths: " .. rebirthCount
            task.wait(0.1)
        else task.wait(0.1) end
    end
end)

task.spawn(function()
    while true do
        if autoCombo and comboTarget then
            local aura = getAura()
            local rebirthAt = comboTarget.req * threshold
            if aura >= rebirthAt then
                isRebirthing = true
                if RequestRebirth then RequestRebirth:InvokeServer() end
                rebirthCount = rebirthCount + 1
                RebirthLabel.Text = "Rebirths: " .. rebirthCount
                if multiplierOn then
                    threshold = threshold * multiplier
                    ThreshBox.Text = formatThresh(threshold)
                end
                task.wait(2)
                isRebirthing = false; currentArea = nil
                local curIdx = getAreaIndex(comboTarget)
                if curIdx < #areas then comboTarget = areas[curIdx + 1] end
                updateStatus()
            end
        end
        task.wait(1)
    end
end)

task.spawn(function()
    while true do
        if zoneGuard and not isRebirthing then
            local serverArea = player:GetAttribute("CurrentArea") or ""
            if serverArea == "" then
                local best = getBestArea(getAura())
                if best then teleport(best.pos); currentArea = best.name end
            end
        end
        task.wait(3)
    end
end)

task.spawn(function()
    while true do
        if autoKothRebirth then
            local aura = getAura()
            if aura >= kothRebirthTarget then
                if RequestRebirth then
                    pcall(function() RequestRebirth:InvokeServer() end)
                end
                kothRebirthCount = kothRebirthCount + 1
                kRebCount.Text = "KOTH Rebirths: " .. kothRebirthCount
                task.wait(1)
            end
        end
        task.wait(0.5)
    end
end)

