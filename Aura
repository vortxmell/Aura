-- Dapat aura sebagai (group, mantissa) untuk comparison rebirth target yang accurate
-- PENTING: Aura_Exponent dalam game adalah INTEGER (e.g. 48 untuk range QDc),
-- jadi mantissa MESTI diambil dari raw Aura attribute, bukan dikira dari exponent.
local function getAuraTier()
    local aura = player:GetAttribute("Aura") or 0
    local exp  = player:GetAttribute("Aura_Exponent")

    -- Tentukan group
    local grp
    if type(exp) == "number" and exp >= 0 then
        grp = math.floor(exp / 3)
    else
        if aura <= 0 then return 0, 0 end
        grp = math.floor(math.log10(aura) / 3)
    end

    -- Mantissa sentiasa dari raw Aura (Aura_Exponent adalah integer, tak boleh pakai untuk mantissa)
    local mantissa
    if aura > 0 then
        mantissa = aura / (10 ^ (grp * 3))
    elseif type(exp) == "number" then
        -- Aura overflow (>1e308): fallback estimate dari exponent
        mantissa = 10 ^ (exp - grp * 3)
    else
        mantissa = 0
    end

    return grp, mantissa
end

