-- Toggle animation
local TweenService = game:GetService("TweenService")
local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad)

local function setToggle(pill, dot, stroke, on)
    if on then
        TweenService:Create(pill, tweenInfo, {BackgroundColor3 = Color3.fromRGB(110, 70, 200)}):Play()
        TweenService:Create(dot, tweenInfo, {
            Position = UDim2.new(0, 19, 0.5, -7),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
        TweenService:Create(stroke, tweenInfo, {Color = Color3.fromRGB(110, 70, 200)}):Play()
    else
        TweenService:Create(pill, tweenInfo, {BackgroundColor3 = Color3.fromRGB(40, 35, 55)}):Play()
        TweenService:Create(dot, tweenInfo, {
            Position = UDim2.new(0, 3, 0.5, -7),
            BackgroundColor3 = Color3.fromRGB(100, 90, 130)
        }):Play()
        TweenService:Create(stroke, tweenInfo, {Color = Color3.fromRGB(60, 45, 90)}):Play()
    end
end

-- Respawn handler
player.CharacterAdded:Connect(function()
    task.wait(3)
    if autoTraining then
        local best = getBestArea(getAura())
        if best then
            teleport(best.pos)
            currentArea = best.name
        end
    end
end)

-- Auto Training loop
local function startTraining()
    trainingThread = task.spawn(function()
        while autoTraining do
            local aura = getAura()
            local best = getBestArea(aura)
            if best then
                if best.name ~= currentArea then
                    currentArea = best.name
                    teleport(best.pos)
                    StatusLabel.Text = "Area: " .. best.name
                end
            else
                StatusLabel.Text = "Area: Belum cukup aura"
            end
            task.wait(5)
        end
    end)
end

-- Auto Rebirth loop
local function startRebirth()
    rebirthThread = task.spawn(function()
        while autoRebirth do
            RequestRebirth:InvokeServer()
            rebirthCount += 1
            RebirthLabel.Text = "Rebirths: " .. rebirthCount
            task.wait(0.1)
        end
    end)
end

-- Button events
TrainBtn.MouseButton1Click:Connect(function()
    autoTraining = not autoTraining
    setToggle(TrainPill, TrainDot, TrainStroke, autoTraining)
    if autoTraining then
        currentArea = nil
        startTraining()
    end
end)

RebirthBtn.MouseButton1Click:Connect(function()
    autoRebirth = not autoRebirth
    setToggle(RebirthPill, RebirthDot, RebirthStroke, autoRebirth)
    if autoRebirth then
        startRebirth()
    end
end)

