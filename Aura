    if threshold < 20 then
        threshold = threshold + 1
        ThreshValue.Text = threshold .. "x"
    end
end)

-- Respawn handler
player.CharacterAdded:Connect(function()
    task.wait(3)
    if autoTraining or autoCombo then
        local best = getBestArea(getAura())
        if best then
            teleport(best.pos)
            currentArea = best.name
            StatusLabel.Text = "Area: " .. best.name
        end
    end
end)

-- Auto Training loop
task.spawn(function()
    while true do
        if autoTraining or autoCombo then
            local aura = getAura()
            local best = getBestArea(aura)
            if best then
                if best.name ~= currentArea then
                    currentArea = best.name
                    teleport(best.pos)
                    StatusLabel.Text = "Area: " .. best.name
                end
            else
                StatusLabel.Text = "Area: Belum cukup aura"
            end
        end
        task.wait(5)
    end
end)

-- Auto Rebirth loop
task.spawn(function()
    while true do
        if autoRebirth then
            RequestRebirth:InvokeServer()
            rebirthCount += 1
            RebirthLabel.Text = "Rebirths: " .. rebirthCount
            task.wait(0.1)
        else
            task.wait(0.1)
        end
    end
end)

-- Combo loop
task.spawn(function()
    while true do
        if autoCombo then
            local aura = getAura()
            local next = getNextArea(aura)
            local shouldRebirth = false

            if next then
                if aura >= next.req * threshold then
                    shouldRebirth = true
                end
            else
                if aura >= 1000 then
                    shouldRebirth = true
                end
            end

            if shouldRebirth then
                RequestRebirth:InvokeServer()
                rebirthCount += 1
                RebirthLabel.Text = "Rebirths: " .. rebirthCount
                task.wait(2)
                currentArea = nil
            end
        end
        task.wait(1)
    end
end)

