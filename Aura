-- ─── KOTH Logic (Hitbox Polling) ─────────────────────────────────────────────
-- Guna workspace.KOTH.AreaHitbox — confirmed berjaya detect player dalam KOTH
local kothHitbox = nil
pcall(function()
    kothHitbox = workspace:WaitForChild("KOTH", 10):WaitForChild("AreaHitbox", 10)
end)

local function getKOTHStatus()
    if not kothHitbox then return false, "—", 0 end
    local ok2, parts = pcall(function()
        return workspace:GetPartsInPart(kothHitbox)
    end)
    if not ok2 or not parts then return false, "—", 0 end
    for _, part in ipairs(parts) do
        for _, p in ipairs(game.Players:GetPlayers()) do
            if p ~= player and p.Character and part:IsDescendantOf(p.Character) then
                return true, p.Name, p:GetAttribute("Aura") or 0
            end
        end
    end
    return false, "—", 0
end

-- ─── KOTH Helper Functions ───────────────────────────────────────────────────
local function isInKOTH()
    if not kothHitbox then return false end
    local c = player.Character
    if not c then return false end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local ok2, parts = pcall(function()
        return workspace:GetPartsInPart(kothHitbox)
    end)
    if not ok2 or not parts then return false end
    for _, part in ipairs(parts) do
        if part:IsDescendantOf(c) then return true end
    end
    return false
end

local function updateKOTHPanel()
    local myAura = getAura()
    local claimed, kingName, kingAura = getKOTHStatus()

    kRowMyAura.Text = fmtA(myAura)
    local myRebirths = player:GetAttribute("Rebirths") or 0
    kRowMyRank.Text = fmtA(myRebirths) .. " reb"

    if isInKOTH() then
        kStatusDot.BackgroundColor3 = PURPLE
        kRowStatus.Text = "👑 Holding KOTH!"
        kRowStatus.TextColor3 = WHITE
        kRowKing.Text = "— (You)"
        kRowKing.TextColor3 = WHITE
        kRowKingAura.Text = fmtA(myAura)
        kRowKingAura.TextColor3 = WHITE
        kRowResult.Text = "You are King!"
        kRowResult.TextColor3 = GREEN
    elseif not claimed then
        kStatusDot.BackgroundColor3 = GREEN
        kRowStatus.Text = "EMPTY ✓"
        kRowStatus.TextColor3 = GREEN
        kRowKing.Text = "—"
        kRowKingAura.Text = "—"
        kRowResult.Text = "Enter now!"
        kRowResult.TextColor3 = GREEN
    else
        local canWin = myAura > kingAura
        kStatusDot.BackgroundColor3 = canWin and WARN or RED
        kRowStatus.Text = "OCCUPIED"
        kRowStatus.TextColor3 = RED
        kRowKing.Text = kingName
        kRowKing.TextColor3 = WHITE
        kRowKingAura.Text = fmtA(kingAura)
        kRowKingAura.TextColor3 = canWin
            and Color3.fromRGB(100,255,150)
            or  Color3.fromRGB(255,100,100)
        kRowResult.Text = canWin and "YES — masuk!" or "NO — hop server"
        kRowResult.TextColor3 = canWin and GREEN or RED
    end
end

