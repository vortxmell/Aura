-- ─── Respawn ─────────────────────────────────────────────────────────────────
player.CharacterAdded:Connect(function()
    task.wait(3)
    if (autoTraining or autoCombo) then
        local aura = getAura()
        local best = getBestArea(aura)
        -- Kalau combo ON, jangan teleport ke target atau beyond kalau belum rebirth
        if autoCombo and comboTarget and not rebirthDone then
            local targetIdx = getAreaIndex(comboTarget)
            if best and getAreaIndex(best) < targetIdx then
                teleport(best.pos)
                currentArea = best.name
                StatusLabel.Text = "Area: " .. best.name
            end
        elseif best then
            teleport(best.pos)
            currentArea = best.name
            StatusLabel.Text = "Area: " .. best.name
        end
    end
end)

-- ─── Auto Training Loop ──────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoTraining or autoCombo then
            local aura = getAura()
            local best = getBestArea(aura)
            if best then
                local targetIdx = comboTarget and getAreaIndex(comboTarget) or 999
                local bestIdx   = getAreaIndex(best)

                -- Kalau combo ON dan belum rebirth untuk target,
                -- block teleport ke target area atau beyond
                local blocked = autoCombo and comboTarget and not rebirthDone
                    and bestIdx >= targetIdx

                if not blocked then
                    if best.name ~= currentArea then
                        currentArea = best.name
                        teleport(best.pos)
                        StatusLabel.Text = "Area: " .. best.name
                    end
                else
                    -- Farm di area sebelum target
                    local farmArea = nil
                    for i = targetIdx - 1, 1, -1 do
                        if aura >= areas[i].req then
                            farmArea = areas[i]
                            break
                        end
                    end
                    if farmArea and farmArea.name ~= currentArea then
                        currentArea = farmArea.name
                        teleport(farmArea.pos)
                        StatusLabel.Text = "Area: " .. farmArea.name .. " (farming)"
                    end
                end
            else
                StatusLabel.Text = "Area: Belum cukup aura"
            end
            updateStatus()
        end
        task.wait(5)
    end
end)

-- ─── Auto Rebirth Loop ───────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoRebirth then
            RequestRebirth:InvokeServer()
            rebirthCount += 1
            RebirthLabel.Text = "Rebirths: " .. rebirthCount
            task.wait(0.1)
        else
            task.wait(0.1)
        end
    end
end)

-- ─── Combo Loop ──────────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoCombo and comboTarget then
            local aura = getAura()
            local rebirthAt = comboTarget.req * threshold

            if aura >= rebirthAt then
                -- Rebirth!
                RequestRebirth:InvokeServer()
                rebirthCount += 1
                RebirthLabel.Text = "Rebirths: " .. rebirthCount
                rebirthDone = true
                task.wait(2)
                currentArea = nil

                -- Auto-advance target kalau user tak pick sendiri
                -- atau kalau userPickedTarget dah selesai (rebirthDone)
                if not userPickedTarget then
                    -- advance ke next area
                    local curIdx = getAreaIndex(comboTarget)
                    if curIdx < #areas then
                        comboTarget = areas[curIdx + 1]
                        rebirthDone = false  -- kena rebirth semula untuk target baru
                    end
                    -- kalau dah max (Fallen Star), kekal & rebirth unlimited
                else
                    -- user dah manually pick, check kalau dah masuk target area
                    local newAura = getAura()
                    if newAura >= comboTarget.req then
                        -- dah boleh masuk, advance auto
                        local curIdx = getAreaIndex(comboTarget)
                        if curIdx < #areas then
                            comboTarget = areas[curIdx + 1]
                            rebirthDone = false
                            userPickedTarget = false  -- reset, bagi auto-advance balik
                        end
                    else
                        rebirthDone = false
                        userPickedTarget = false
                    end
                end
                updateStatus()
            end
        end
        task.wait(1)
    end
end)

