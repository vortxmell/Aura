game:GetService("Players").LocalPlayer.OnTeleport:Connect(function(state)
    if state == Enum.TeleportState.RequestedFromServer then
        warn("[AutoHub] Server teleport detected")
        task.wait(3)
        pcall(function() TeleportService:Teleport(placeId, player) end)
    end
end)

game:GetService("Players").LocalPlayer.Idled:Connect(function(time)
    warn("[AutoHub] Player idle detected - " .. tostring(time) .. "s idle")
end)

game:GetService("Players").PlayerRemoving:Connect(function(p)
    if p == player then warn("[AutoHub] LocalPlayer removing") end
end)

print("Auto Hub v3 loaded! KOTH = hitbox polling + Auto Enter")
