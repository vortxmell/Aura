-- Returns: isSpawned (bool), timerText (string), position (Vector3 or nil)
local function getCZInfo()
    local czFolder = workspace:FindFirstChild("ActiveCursedZone")
    if czFolder then
        local hitbox = czFolder:FindFirstChild("AreaHitbox") or czFolder:FindFirstChild("Hitbox")
        local pos = hitbox and hitbox.Position or nil

        -- Kira radius dari actual hitbox size
        local czRadius = 50 -- fallback default
        if hitbox then
            pcall(function()
                local s = hitbox.Size
                czRadius = math.max(s.X, s.Z) / 2
            end)
        end

        local timerText = "Active"
        pcall(function()
            local czt = player.PlayerGui:FindFirstChild("Hud")
                and player.PlayerGui.Hud:FindFirstChild("CursedZoneTimer")
            if czt then
                local m = czt.Text:match("(%d+:%d+)$")
                if m then timerText = m end
            end
        end)

        return true, timerText, pos, czRadius
    end

    local spawnCountdown = nil
    pcall(function()
        local czt = player.PlayerGui:FindFirstChild("Hud")
            and player.PlayerGui.Hud:FindFirstChild("CursedZoneTimer")
        if czt then
            local rawText = czt.Text or ""
            local m = rawText:match("(%d+:%d+)$")
            if m and rawText:lower():find("spawn") then
                spawnCountdown = m
            end
        end
    end)

    return false, spawnCountdown, nil
end

-- NEW: Parse "MM:SS" atau "SS" → total seconds, nil kalau fail
local function parseCZTimer(timerText)
    if not timerText then return nil end
    local m, s = timerText:match("^(%d+):(%d+)$")
    if m and s then
        return tonumber(m) * 60 + tonumber(s)
    end
    local ss = timerText:match("^(%d+)$")
    if ss then return tonumber(ss) end
    return nil
end

local czTeleportDebounce = false

local function updateCZPanel()
    local spawned, timerText, czPos = getCZInfo()

    if spawned then
        czStatusDot.BackgroundColor3 = CURSE
        czRowStatus.Text      = "Spawned 💀"
        czRowStatus.TextColor3 = CURSE

        czRowTimer.Text       = timerText or "Active"
        czRowTimer.TextColor3 = WARN

        if czPos then
            czRowLocation.Text = string.format("%.0f, %.0f, %.0f", czPos.X, czPos.Y, czPos.Z)
            czRowLocation.TextColor3 = Color3.fromRGB(180, 180, 255)
        else
            czRowLocation.Text = "No hitbox"
            czRowLocation.TextColor3 = DIM
        end

        if autoCZTeleport and czPos and not czTeleportDebounce then
            czTeleportDebounce = true
            teleport(czPos + Vector3.new(0, 5, 0))
            czTpStatus.Text      = "✅ Teleported!"
            czTpStatus.TextColor3 = GREEN
        end
    else
        czTeleportDebounce = false

        czStatusDot.BackgroundColor3 = RED
        czRowStatus.Text      = "Despawned 🔴"
        czRowStatus.TextColor3 = RED

        if timerText then
            czRowTimer.Text      = timerText .. " (spawn)"
            czRowTimer.TextColor3 = Color3.fromRGB(150, 150, 255)
        else
            czRowTimer.Text      = "Waiting..."
            czRowTimer.TextColor3 = DIM
        end

        czRowLocation.Text = "—"
        czRowLocation.TextColor3 = DIM

        if autoCZTeleport and not autoCZServerHop then
            czTpStatus.Text      = "⏳ Tunggu zone spawn..."
            czTpStatus.TextColor3 = WARN
        elseif not autoCZTeleport and not autoCZServerHop then
            czTpStatus.Text      = "💤 Waiting zone..."
            czTpStatus.TextColor3 = DIM
        end
    end
end

