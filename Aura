btnSave.MouseButton1Click:Connect(function()
    if not hasFS then setConfigStatus("⚠ Executor tak support!", true); return end
    local name = configNameBox.Text:gsub("%s+", "")
    if name == "" then setConfigStatus("⚠ Enter config name!", true); return end
    local configs = loadConfigFile()
    local count = 0
    for k,_ in pairs(configs) do if k ~= AUTOLOAD_KEY then count = count + 1 end end
    if count >= 10 and not configs[name] then setConfigStatus("⚠ Max 10 configs!", true); return end
    configs[name] = getCurrentSettings(); saveConfigFile(configs)
    selectedCfg = name; configNameBox.Text = ""
    setConfigStatus("✓ Saved: " .. name); rebuildConfigList()
end)

btnLoad.MouseButton1Click:Connect(function()
    if not selectedCfg then setConfigStatus("⚠ Select a config!", true); return end
    local configs = loadConfigFile()
    if configs[selectedCfg] then
        isLoading = true
        applySettings(configs[selectedCfg])
        setConfigStatus("✓ Loaded: " .. selectedCfg)
        task.delay(1, function() isLoading = false end)
    else setConfigStatus("! Config not found!", true) end
end)

btnDelete.MouseButton1Click:Connect(function()
    if not selectedCfg then setConfigStatus("⚠ Select a config!", true); return end
    local configs = loadConfigFile()
    if configs[selectedCfg] then
        local deleted = selectedCfg
        configs[selectedCfg] = nil
        if configs[AUTOLOAD_KEY] == selectedCfg then configs[AUTOLOAD_KEY] = nil end
        saveConfigFile(configs); selectedCfg = nil
        setConfigStatus("🗑 Deleted: " .. deleted); rebuildConfigList()
    end
end)

btnAutoLoad.MouseButton1Click:Connect(function()
    if not selectedCfg then setConfigStatus("⚠ Select a config!", true); return end
    local configs = loadConfigFile()
    if configs[AUTOLOAD_KEY] == selectedCfg then
        configs[AUTOLOAD_KEY] = nil; setConfigStatus("* Auto load removed")
    else
        configs[AUTOLOAD_KEY] = selectedCfg; setConfigStatus("* Auto load: " .. selectedCfg)
    end
    saveConfigFile(configs); rebuildConfigList()
end)

