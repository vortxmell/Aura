-- ─── Auto Training Loop ──────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoTraining or autoCombo then
            local aura = getAura()
            local best = getBestArea(aura)
            if best then
                local targetIdx = comboTarget and getAreaIndex(comboTarget) or 999
                local bestIdx   = getAreaIndex(best)
                local blocked   = autoCombo and comboTarget and not rebirthDone and bestIdx >= targetIdx
                if not blocked then
                    if best.name ~= currentArea then
                        currentArea = best.name
                        teleport(best.pos)
                        StatusLabel.Text = "Area: " .. best.name
                    end
                else
                    local farmArea = nil
                    for i = targetIdx-1, 1, -1 do
                        if aura >= areas[i].req then farmArea = areas[i]; break end
                    end
                    if farmArea and farmArea.name ~= currentArea then
                        currentArea = farmArea.name
                        teleport(farmArea.pos)
                        StatusLabel.Text = "Area: " .. farmArea.name .. " (farming)"
                    end
                end
            else
                StatusLabel.Text = "Area: Belum cukup aura"
            end
            updateStatus()
        end
        task.wait(5)
    end
end)

-- ─── Auto Rebirth Loop ───────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoRebirth then
            RequestRebirth:InvokeServer()
            rebirthCount += 1
            RebirthLabel.Text = "Rebirths: " .. rebirthCount
            task.wait(0.1)
        else
            task.wait(0.1)
        end
    end
end)

-- ─── Combo Loop ──────────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if autoCombo and comboTarget then
            local aura      = getAura()
            local rebirthAt = comboTarget.req * threshold
            if aura >= rebirthAt then
                RequestRebirth:InvokeServer()
                rebirthCount += 1
                RebirthLabel.Text = "Rebirths: " .. rebirthCount
                rebirthDone = true
                task.wait(2)
                currentArea = nil
                if not userPickedTarget then
                    local curIdx = getAreaIndex(comboTarget)
                    if curIdx < #areas then
                        comboTarget = areas[curIdx+1]
                        rebirthDone = false
                    end
                else
                    local newAura = getAura()
                    if newAura >= comboTarget.req then
                        local curIdx = getAreaIndex(comboTarget)
                        if curIdx < #areas then
                            comboTarget = areas[curIdx+1]
                            rebirthDone = false
                            userPickedTarget = false
                        end
                    else
                        rebirthDone = false
                        userPickedTarget = false
                    end
                end
                updateStatus()
            end
        end
        task.wait(1)
    end
end)

-- ─── Init ────────────────────────────────────────────────────────────────────
local function initDefaultTarget()
    local aura = getAura()
    local next = getNextArea(aura)
    comboTarget = next or areas[#areas]
    rebirthDone = false
    userPickedTarget = false
    updateStatus()
end

initDefaultTarget()
updateStatus()
