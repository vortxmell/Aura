-- ============================================================
-- NUMBER FORMATTING — ported dari game source (SuffixBoardFrame)
-- Support sampai 1e1803 (Sxc), sama exact dengan game
-- ============================================================
local _s0 = {[0]="","K","M","B","T","Qa","Qi","Sx","Sp","Oc","No"}
local _s1 = {[0]="","U","D","T","q","Q","s","S","O","N"}
local _s2 = {
    "Dc","Vg","Tg","Qg","Qig","Sxg","Spg","Og","Ng",
    "Ce","DcCe","VgCe","TgCe","QgCe","QigCe","SxgCe","SpgCe","OgCe","NgCe",
    "Dc","DcDc","VgDc","TgDc","QgDc","QigDc","SxgDc","SpgDc","OgDc","NgDc",
    "Tc","DcTc","VgTc","TgTc","QgTc","QigTc","SxgTc","SpgTc","OgTc","NgTc",
    "Qg","DcQg","VgQg","TgQg","QgQg","QigQg","SxgQg","SpgQg","OgQg","NgQg",
    "Qi","DcQi","VgQi","TgQi","QgQi","QigQi","SxgQi","SpgQi","OgQi","NgQi",
    "Sxc"
}

-- Group g → suffix label (g=1→K, g=16→QDc, g=601→Sxc)
local function getSuffix(g)
    local s = _s0[g]
    if s ~= nil then return s end
    if g < 11 then return "e"..tostring(g*3) end
    local tier = math.floor((g - 1) / 10)
    local mod  = (g - 1) % 10
    local base = _s2[tier]
    if base == nil then return "e"..tostring(g*3) end
    return (_s1[mod] or "") .. base
end

-- Format number untuk display (guna log10, works semua range)
local function formatNum(n)
    if not n or n <= 0 then return "0" end
    if n < 1e3 then return tostring(math.floor(n)) end
    local logVal = math.log10(n)
    local g = math.min(math.floor(logVal / 3), 601)
    local m = 10 ^ (logVal - g * 3)
    return string.format("%.1f%s", m, getSuffix(g))
end

local function fmtA(n)
    if not n or n <= 0 then return "0" end
    if n < 1e3 then return string.format("%.0f", n) end
    local logVal = math.log10(n)
    local g = math.min(math.floor(logVal / 3), 601)
    local m = 10 ^ (logVal - g * 3)
    return string.format("%.2f%s", m, getSuffix(g))
end

