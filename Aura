local threshold = 2

local suffixes = {
    {1e36, "Dc"}, {1e33, "No"}, {1e30, "Oc"}, {1e27, "Sp"},
    {1e24, "Sx"}, {1e21, "Qi"}, {1e18, "Qa"}, {1e15, "T"},
    {1e12, "B"},  {1e9,  "M"},  {1e6,  "K"},
}

local function formatNum(n)
    for _, s in ipairs(suffixes) do
        if n >= s[1] then
            return string.format("%.1f%s", n / s[1], s[2])
        end
    end
    return tostring(math.floor(n))
end

local function getAura()
    return player:GetAttribute("Aura") or 0
end

local function teleport(pos)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos)
    end
end

local function getBestArea(aura)
    local best = nil
    for _, area in ipairs(areas) do
        if aura >= area.req then best = area end
    end
    return best
end

local function getNextArea(aura)
    for _, area in ipairs(areas) do
        if aura < area.req then return area end
    end
    return nil
end

