        TargetVal.Text      = comboTarget.name
        local rebirthAt     = comboTarget.req * threshold
        NextAreaLabel.Text  = "Target: " .. comboTarget.name
        ReqLabel.Text       = "Req: " .. formatNum(comboTarget.req)
        RebirthAtLabel.Text = "Rebirth at: " .. formatNum(rebirthAt)
        WarnLabel.Text      = getAura() >= comboTarget.req and "⚠ Aura dah lepas target" or ""
    else
        TargetVal.Text      = "—"
        NextAreaLabel.Text  = "Target: —"
        ReqLabel.Text       = "Req: —"
        RebirthAtLabel.Text = "Rebirth at: —"
        WarnLabel.Text      = ""
    end
end

