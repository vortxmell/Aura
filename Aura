    activeTab = tab
    PanelFarm.Visible     = (tab == "farm")
    PanelConfig.Visible   = (tab == "config")
    PanelAnalyzer.Visible = (tab == "analyzer")
    PanelKOTH.Visible     = (tab == "koth")

    TabFarm.TextColor3     = tab == "farm"     and WHITE or DIM
    TabConfig.TextColor3   = tab == "config"   and WHITE or DIM
    TabAnalyzer.TextColor3 = tab == "analyzer" and WHITE or DIM
    TabKOTH.TextColor3     = tab == "koth"     and WHITE or DIM

    TweenService:Create(TabFarm,     tweenInfo, {BackgroundTransparency = tab=="farm"     and 0.6 or 1}):Play()
    TweenService:Create(TabConfig,   tweenInfo, {BackgroundTransparency = tab=="config"   and 0.6 or 1}):Play()
    TweenService:Create(TabAnalyzer, tweenInfo, {BackgroundTransparency = tab=="analyzer" and 0.6 or 1}):Play()
    TweenService:Create(TabKOTH,     tweenInfo, {BackgroundTransparency = tab=="koth"     and 0.6 or 1}):Play()

    local indicatorY = tab=="farm" and 13 or tab=="koth" and 55 or tab=="config" and 97 or 139
    TweenService:Create(TabIndicator, tweenInfo, {Position = UDim2.new(0,0,0,indicatorY)}):Play()

    -- Update KOTH panel terus bila switch ke tab tu
    if tab == "koth" then updateKOTHPanel() end
end

