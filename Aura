-- ============================================================
-- AUTO KOTH LOOP (Force Hop + Auto Enter + Auto Server Hop)
-- ============================================================
task.spawn(function()
    local killed     = false
    local wasHolding = false
    killEvent.Event:Connect(function() killed = true end)

    local function getKOTHPos()
        local ok, hitbox = pcall(function()
            return workspace:WaitForChild("KOTH", 5):WaitForChild("AreaHitbox", 5)
        end)
        if ok and hitbox then return hitbox.Position + Vector3.new(0, 3, 0) end
        return nil
    end

    while not killed and ScreenGui.Parent do
        -- Force Hop
        if forceHop then
            forceHop = false
            doServerHop("Force", kAutoStatus)
            task.wait(3)

        elseif autoKOTH and not kothHopping then
            local myAura               = getAura()
            local claimed, _, kingAura = getKOTHStatus()
            local inKOTH               = isInKOTH()
            local KOTH_POS             = getKOTHPos()

            if inKOTH then
                -- Player dah dalam KOTH
                if claimed and kingAura > myAura then
                    -- Ada king yang lebih kuat — hop keluar
                    wasHolding = false
                    if autoServerHop then
                        kAutoStatus.Text      = "⚠️ Threat! Hopping..."
                        kAutoStatus.TextColor3 = RED
                        doServerHop("Threat", kAutoStatus)
                    else
                        kAutoStatus.Text      = "⚠️ Threat! Staying..."
                        kAutoStatus.TextColor3 = WARN
                    end
                else
                    wasHolding             = true
                    kAutoStatus.Text       = "👑 Holding KOTH!"
                    kAutoStatus.TextColor3 = WHITE
                end

            else
                -- Player di luar KOTH
                if wasHolding then
                    -- Baru keluar dari KOTH
                    if claimed and kingAura > myAura then
                        wasHolding = false
                        if autoServerHop then
                            kAutoStatus.Text      = "💀 Killed! Hopping..."
                            kAutoStatus.TextColor3 = RED
                            doServerHop("Killed", kAutoStatus)
                            task.wait(5)
                        else
                            kAutoStatus.Text      = "💀 Killed! Checking..."
                            kAutoStatus.TextColor3 = WARN
                            task.wait(2)
                            local claimed2, _, kingAura2 = getKOTHStatus()
                            local myAura2 = getAura()
                            if not claimed2 or myAura2 > kingAura2 then
                                kAutoStatus.Text      = "🔁 Re-entering..."
                                kAutoStatus.TextColor3 = WARN
                                if KOTH_POS then teleport(KOTH_POS) end
                            else
                                kAutoStatus.Text      = "💪 King strong — waiting"
                                kAutoStatus.TextColor3 = RED
                            end
                        end
                    else
                        wasHolding             = false
                        kAutoStatus.Text       = "🔁 Re-entering..."
                        kAutoStatus.TextColor3 = WARN
                        if KOTH_POS then teleport(KOTH_POS) end
                    end

                elseif not claimed then
                    -- KOTH kosong — masuk terus
                    kAutoStatus.Text      = "🟢 Empty — entering!"
                    kAutoStatus.TextColor3 = GREEN
                    if KOTH_POS then teleport(KOTH_POS) end

                elseif myAura > kingAura then
                    -- King lemah — masuk dan ambil alih
                    kAutoStatus.Text      = "⚡ King weak — entering!"
                    kAutoStatus.TextColor3 = WARN
                    if KOTH_POS then teleport(KOTH_POS) end

                else
                    -- King lebih kuat — hop atau tunggu
                    if autoServerHop then
                        kAutoStatus.Text      = "💪 King strong — hopping!"
                        kAutoStatus.TextColor3 = RED
                        doServerHop("Strong King", kAutoStatus)
                    else
                        kAutoStatus.Text      = "💪 King strong — waiting"
                        kAutoStatus.TextColor3 = RED
                    end
                end
            end

        elseif not autoKOTH then
            kothHopping = false
        end

        task.wait(3)
    end
end)

-- ============================================================
-- AUTO SERVER HOP CZ LOOP
-- ============================================================
task.spawn(function()
    local killed = false
    killEvent.Event:Connect(function() killed = true end)

    local hopScheduled = false

    while not killed and ScreenGui.Parent do
        if autoCZServerHop then
            local spawned, timerText, czPos, czRadius = getCZInfo()

            if not spawned then
                local secs = parseCZTimer(timerText)

                if czInsideZone then
                    -- Player tadi dah dalam zone, zone baru habis → hop terus
                    czInsideZone = false
                    if not hopScheduled then
                        hopScheduled = true
                        task.wait(1.5)
                        if autoCZServerHop then
                            doServerHop("Zone habis", czTpStatus)
                        end
                        hopScheduled = false
                    end

                elseif secs ~= nil and secs > 20 then
                    -- Timer lama lagi → hop cari server lain
                    if not hopScheduled then
                        hopScheduled = true
                        czTpStatus.Text       = "🔀 Timer " .. (timerText or "?") .. " — hopping..."
                        czTpStatus.TextColor3 = WARN
                        task.wait(1.5)
                        if autoCZServerHop then
                            doServerHop((timerText or "?") .. " lagi", czTpStatus)
                        end
                        hopScheduled = false
                    end

                elseif secs ~= nil and secs <= 20 then
                    -- Nak spawn dalam masa terdekat → standby, reset flag
                    hopScheduled = false
                    czTpStatus.Text       = "⏳ Spawn dalam " .. (timerText or "?") .. ", standby..."
                    czTpStatus.TextColor3 = Color3.fromRGB(150, 220, 255)

                else
                    hopScheduled = false
                    czTpStatus.Text       = "🔍 Monitoring zone..."
                    czTpStatus.TextColor3 = DIM
                end

            else
                -- Zone spawned → reset hopScheduled, check proximity player
                hopScheduled = false
                if czPos and czRadius then
                    local c   = player.Character
                    local hrp = c and c:FindFirstChild("HumanoidRootPart")
                    if hrp and (hrp.Position - czPos).Magnitude < czRadius then
                        if not czInsideZone then
                            czInsideZone = true
                            czTpStatus.Text       = "✅ Dalam zone!"
                            czTpStatus.TextColor3 = GREEN
                        end
                    end
                end
            end
        else
            czInsideZone = false
            hopScheduled = false
        end

        task.wait(2)
    end
end)

