local function loadConfigFile()
    if not hasFS then return {} end
    local ok2, data = pcall(readfile, CONFIG_FILE)
    if not ok2 or not data or data == "" then return {} end
    local ok3, t = pcall(function() return game:GetService("HttpService"):JSONDecode(data) end)
    return (ok3 and t) or {}
end

local function saveConfigFile(configs)
    if not hasFS then setConfigStatus("⚠ Executor tak support!", true); return end
    pcall(function()
        writefile(CONFIG_FILE, game:GetService("HttpService"):JSONEncode(configs))
    end)
end

local function getCurrentSettings()
    return {
        autoTraining    = autoTraining,
        autoRebirth     = autoRebirth,
        autoCombo       = autoCombo,
        zoneGuard       = zoneGuard,
        multiplierOn    = multiplierOn,
        threshold       = threshold,
        multiplier      = multiplier,
        comboTargetName = comboTarget and comboTarget.name or nil,
        autoKOTH        = autoKOTH,
        autoServerHop   = autoServerHop,
        autoKothRebirth = autoKothRebirth,
        kothRebirthVal  = kothRebirthVal,
        kothRebirthUnit = kothRebirthUnit,
    }
end

local function applySettings(s)
    if not s then return end
    if s.threshold  ~= nil then threshold  = s.threshold  end
    if s.multiplier ~= nil then multiplier = s.multiplier end
    if s.comboTargetName then
        for _,a in ipairs(areas) do
            if a.name == s.comboTargetName then comboTarget = a; break end
        end
    end
    if s.multiplierOn    ~= nil then multiplierOn    = s.multiplierOn;    setToggle(MultPill,    MultDot,    MultStroke,    multiplierOn)    end
    if s.autoTraining    ~= nil then autoTraining    = s.autoTraining;    setToggle(TrainPill,   TrainDot,   TrainStroke,   autoTraining)    end
    if s.autoRebirth     ~= nil then autoRebirth     = s.autoRebirth;     setToggle(RebirthPill, RebirthDot, RebirthStroke, autoRebirth)     end
    if s.autoCombo       ~= nil then autoCombo       = s.autoCombo;       setToggle(ComboPill,   ComboDot,   ComboStroke,   autoCombo)       end
    if s.zoneGuard       ~= nil then zoneGuard       = s.zoneGuard;       setToggle(ZonePill,    ZoneDot,    ZoneStroke,    zoneGuard)       end
    if s.autoKOTH        ~= nil then
        autoKOTH = s.autoKOTH
        setToggle(kAutoPill, kAutoDot, kAutoStroke, autoKOTH)
        kAutoStatus.Text = autoKOTH and "🔄 Running..." or "💤 Idle"
        kAutoStatus.TextColor3 = autoKOTH and GREEN or DIM
    end
    if s.autoServerHop ~= nil then
        autoServerHop = s.autoServerHop
        setToggle(kHopPill, kHopDot, kHopStroke, autoServerHop)
    end
    if s.autoKothRebirth ~= nil then
        autoKothRebirth = s.autoKothRebirth
        setToggle(kRebPill, kRebDot, kRebStroke, autoKothRebirth)
        kRebStatus.Text = autoKothRebirth and "ON" or "OFF"
        kRebStatus.TextColor3 = autoKothRebirth and GREEN or RED
    end
    if s.kothRebirthVal  ~= nil then kothRebirthVal  = s.kothRebirthVal;  kRebInput.Text = tostring(kothRebirthVal) end
    if s.kothRebirthUnit ~= nil then
        kothRebirthUnit = s.kothRebirthUnit
        kRebUnitBtn.Text = kothRebirthUnit .. " ▾"
    end
    updateKRebTarget()
    ThreshBox.Text = formatThresh(threshold); MultBox.Text = formatThresh(multiplier)
    updateStatus()
end

local function autoSave()
    task.spawn(function()
        task.wait(0.5)
        if isLoading then return end  -- skip if load just happened (prevent race condition)
        local configs = loadConfigFile()
        if selectedCfg and configs[selectedCfg] then
            configs[selectedCfg] = getCurrentSettings()
            saveConfigFile(configs)
        end
    end)
end

local function rebuildConfigList()
    for _, c in pairs(configList:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local configs = loadConfigFile()
    local autoLoadName = configs[AUTOLOAD_KEY]
    btnAutoLoad.Text = autoLoadName and ("⚡ Auto: "..autoLoadName) or "⚡ Auto Load: None"
    btnAutoLoad.BackgroundColor3 = autoLoadName and Color3.fromRGB(20,100,30) or Color3.fromRGB(60,40,10)
    local hasAny = false
    for name, _ in pairs(configs) do
        if name ~= AUTOLOAD_KEY then
            hasAny = true
            local isAuto = autoLoadName == name
            local isSel  = selectedCfg == name
            local item = Instance.new("TextButton")
            item.Size = UDim2.new(1,0,0,22)
            item.BackgroundColor3 = isSel and Color3.fromRGB(60,40,100) or Color3.fromRGB(25,20,38)
            item.BackgroundTransparency = isSel and 0 or 0.3; item.BorderSizePixel = 0
            item.Text = (isAuto and "⚡ " or "  ") .. name
            item.TextColor3 = isSel and WHITE or (isAuto and GREEN or DIM)
            item.TextSize = 10; item.Font = Enum.Font.Gotham
            item.TextXAlignment = Enum.TextXAlignment.Left; item.Parent = configList
            Instance.new("UICorner", item).CornerRadius = UDim.new(0,4)
            item.MouseButton1Click:Connect(function() selectedCfg = name; rebuildConfigList() end)
        end
    end
    if not hasAny then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1,0,0,22); empty.BackgroundTransparency = 1
        empty.Text = "  No configs saved"; empty.TextColor3 = DIM
        empty.TextSize = 9; empty.Font = Enum.Font.Gotham
        empty.TextXAlignment = Enum.TextXAlignment.Left; empty.Parent = configList
    end
end

