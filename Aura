-- ============================================================
-- SERVER HOP (Delta-compatible: HttpGet + TeleportToPlaceInstance)
-- ============================================================
local lastHopTime   = 0
local hopCount      = 0
local isTeleporting = false

local function doServerHop(reason, statusLabel)
    local cooldown = math.min(12 + (hopCount * 2), 25)
    if tick() - lastHopTime < cooldown then
        local remaining = math.ceil(cooldown - (tick() - lastHopTime))
        if statusLabel then
            statusLabel.Text      = "⏳ Cooldown " .. remaining .. "s..."
            statusLabel.TextColor3 = DIM
        end
        return
    end
    lastHopTime = tick()
    hopCount   += 1

    if statusLabel then
        statusLabel.Text      = "🔍 Scanning servers..."
        statusLabel.TextColor3 = WARN
    end

    task.spawn(function()
        local currentJobId = game.JobId
        local target       = nil
        local bestCount    = math.huge
        local cursor       = ""

        -- Scan 1 page je — cukup untuk cari server lain, tak perlu banyak
        local url = string.format(
            "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100",
            placeId
        )

        -- game:HttpGet OK pada Delta (request() crash, HttpGet OK)
        local ok, result = pcall(function()
            return game:HttpGet(url)
        end)

        if ok and result then
            local ok2, data = pcall(function()
                return game:GetService("HttpService"):JSONDecode(result)
            end)
            if ok2 and data and data.data then
                for _, server in ipairs(data.data) do
                    if server.id ~= currentJobId
                    and server.playing
                    and server.playing >= 1 then
                        -- Pilih server paling sikit player
                        if server.playing < bestCount then
                            bestCount = server.playing
                            target    = server
                        end
                        -- Kalau jumpa solo server terus guna
                        if server.playing == 1 then break end
                    end
                end
            end
        end

        if target then
            if statusLabel then
                statusLabel.Text      = "🚀 Hopping -> " .. target.playing .. " player(s)"
                statusLabel.TextColor3 = WARN
            end
            task.wait(1 + math.random())
            isTeleporting = true
            local hopOk = pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, target.id)
            end)
            if not hopOk then
                -- Fallback kalau TeleportToPlaceInstance fail
                hopOk = pcall(function()
                    TeleportService:Teleport(placeId)
                end)
            end
            if not hopOk then
                isTeleporting = false
                if statusLabel then
                    statusLabel.Text      = "❌ Teleport failed"
                    statusLabel.TextColor3 = RED
                end
                task.wait(5)
                kothHopping = false
            end
        else
            -- Tak jumpa server lain — guna Teleport random
            if statusLabel then
                statusLabel.Text      = "🎲 No scan result, random hop..."
                statusLabel.TextColor3 = WARN
            end
            task.wait(1)
            isTeleporting = true
            local hopOk = pcall(function()
                TeleportService:Teleport(placeId)
            end)
            if not hopOk then
                isTeleporting = false
                if statusLabel then
                    statusLabel.Text      = "❌ Teleport failed"
                    statusLabel.TextColor3 = RED
                end
                task.wait(5)
                kothHopping = false
            end
        end
    end)
end

