-- ─── HTTP Helper ──────────────────────────────────────────────────────────────
local function httpGet(url)
    -- Cuba request() dulu (Delta/Synapse style)
    if typeof(request) == "function" then
        local ok2, res = pcall(request, {Url = url, Method = "GET"})
        if ok2 and res and res.Body then
            return true, res.Body
        end
    end
    -- Fallback HttpGet
    if typeof(game.HttpGet) == "function" then
        local ok2, res = pcall(function() return game:HttpGet(url) end)
        if ok2 then return true, res end
    end
    -- Fallback syn.request
    if typeof(syn) == "table" and typeof(syn.request) == "function" then
        local ok2, res = pcall(syn.request, {Url = url, Method = "GET"})
        if ok2 and res and res.Body then
            return true, res.Body
        end
    end
    return false, "No HTTP method available"
end

-- ─── Server Hop Logic ─────────────────────────────────────────────────────────
local hopping = false

local function hopToLeast()
    if hopping then return end
    hopping = true
    TeleBtn.Text = "⏳ Searching..."
    TeleBtn.BackgroundColor3 = Color3.fromRGB(60, 40, 60)

    task.spawn(function()
        local currentJobId = game.JobId
        local bestServer = nil
        local bestCount = math.huge
        local cursor = ""

        for page = 1, 3 do
            local url = string.format(
                "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100",
                placeId
            )
            if cursor ~= "" then
                url = url .. "&cursor=" .. cursor
            end

            StatusLabel.Text = "Fetching page " .. page .. "..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 80)

            local ok2, body = httpGet(url)
            if not ok2 then
                StatusLabel.Text = "❌ HTTP fail: " .. tostring(body)
                StatusLabel.TextColor3 = Color3.fromRGB(220, 80, 80)
                hopping = false
                TeleBtn.Text = "🚀 Hop Now"
                TeleBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 160)
                return
            end

            local ok3, data = pcall(function()
                return HttpService:JSONDecode(body)
            end)
            if not ok3 or not data or not data.data then
                StatusLabel.Text = "❌ JSON decode fail"
                StatusLabel.TextColor3 = Color3.fromRGB(220, 80, 80)
                hopping = false
                TeleBtn.Text = "🚀 Hop Now"
                TeleBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 160)
                return
            end

            for _, server in ipairs(data.data) do
                if server.id ~= currentJobId and server.playing ~= nil then
                    if server.playing < bestCount then
                        bestCount = server.playing
                        bestServer = server
                    end
                end
            end

            if data.nextPageCursor and data.nextPageCursor ~= "" then
                cursor = data.nextPageCursor
            else
                break
            end
        end

        if bestServer then
            StatusLabel.Text = string.format("✅ Found! %d players. Hopping...", bestCount)
            StatusLabel.TextColor3 = Color3.fromRGB(80, 200, 120)
            task.wait(1.5)
            pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, bestServer.id, player)
            end)
        else
            StatusLabel.Text = "❌ No server found"
            StatusLabel.TextColor3 = Color3.fromRGB(220, 80, 80)
            hopping = false
            TeleBtn.Text = "🚀 Hop Now"
            TeleBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 160)
        end
    end)
end

