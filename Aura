-- ============================================================
-- THRESHOLD / MULTIPLIER
-- ============================================================
local function applyThreshold(val)
    local n = tonumber(val)
    if n and n > 0 then threshold = math.max(0.1, n) end
    ThreshBox.Text = formatThresh(threshold); updateStatus()
end
ThreshMinus.MouseButton1Click:Connect(function()
    threshold = math.max(0.1, math.floor((threshold-0.1)*10+0.5)/10)
    ThreshBox.Text = formatThresh(threshold); updateStatus()
end)
ThreshPlus.MouseButton1Click:Connect(function()
    threshold = math.floor((threshold+0.1)*10+0.5)/10
    ThreshBox.Text = formatThresh(threshold); updateStatus()
end)
ThreshBox.FocusLost:Connect(function() applyThreshold(ThreshBox.Text) end)

local function applyMultiplier(val)
    local n = tonumber(val)
    if n and n > 0 then multiplier = math.max(0.1, n) end
    MultBox.Text = formatThresh(multiplier)
end
MultMinus.MouseButton1Click:Connect(function()
    multiplier = math.max(0.1, math.floor((multiplier-0.1)*10+0.5)/10)
    MultBox.Text = formatThresh(multiplier)
end)
MultPlus.MouseButton1Click:Connect(function()
    multiplier = math.floor((multiplier+0.1)*10+0.5)/10
    MultBox.Text = formatThresh(multiplier)
end)
MultBox.FocusLost:Connect(function() applyMultiplier(MultBox.Text) end)

