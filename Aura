-- ============================================================
-- SERVER HOP
-- ============================================================
local lastHopTime = 0
local hopCount    = 0

local function hopToLeastPopulated(reason)
    if kothHopping then return end
    local cooldown = math.min(12 + (hopCount * 2), 25)
    if tick() - lastHopTime < cooldown then
        local remaining = math.ceil(cooldown - (tick() - lastHopTime))
        kAutoStatus.Text       = "⏳ Hop cooldown " .. remaining .. "s..."
        kAutoStatus.TextColor3 = DIM
        return
    end
    lastHopTime = tick()
    hopCount   += 1
    kothHopping = true
    kAutoStatus.Text      = "🔄 Scanning... (" .. (reason or "?") .. ")"
    kAutoStatus.TextColor3 = WARN

    task.spawn(function()
        local currentJobId = game.JobId
        local bestServer, soloServer = nil, nil
        local bestCount    = math.huge
        local allServers   = {}
        local cursor       = ""
        local totalScanned = 0

        local maxPages = math.random(2, 5)
        for page = 1, maxPages do
            kAutoStatus.Text = string.format("🔍 Scanning page %d/%d...", page, maxPages)

            local url = string.format(
                "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100",
                placeId
            )
            if cursor ~= "" then url = url .. "&cursor=" .. cursor end

            local ok, result = pcall(function()
                return (typeof(request) == "function"
                    and request({Url = url, Method = "GET"}).Body)
                    or game:HttpGet(url)
            end)
            if not ok then
                kAutoStatus.Text = "⚠ API error pg " .. page
                task.wait(0.5); break
            end

            local ok2, data = pcall(function() return HttpService:JSONDecode(result) end)
            if not ok2 or not data or not data.data then break end

            for _, server in ipairs(data.data) do
                if server.id ~= currentJobId and server.playing and server.playing >= 1 then
                    totalScanned += 1
                    table.insert(allServers, server)
                    if server.playing == 1 and not soloServer then
                        soloServer = server
                    end
                    if server.playing < bestCount then
                        bestCount  = server.playing
                        bestServer = server
                    end
                end
            end

            if soloServer then
                kAutoStatus.Text = "✅ Solo server found!"; break
            end

            if data.nextPageCursor and data.nextPageCursor ~= "" then
                cursor = data.nextPageCursor; task.wait(0.2)
            else
                break
            end
        end

        local target = soloServer or bestServer
        if not target and #allServers > 0 then
            target = allServers[math.random(1, #allServers)]
            kAutoStatus.Text = "🎲 Random fallback server"
        end

        if target then
            kAutoStatus.Text = string.format(
                "🚀 Hopping -> %d player(s) [scanned %d]",
                target.playing, totalScanned
            )
            task.wait(1.5 + math.random() * 2)
            pcall(TeleportService.TeleportToPlaceInstance, TeleportService, placeId, target.id, player)
        else
            kAutoStatus.Text      = string.format("❌ No server found (%d scanned)", totalScanned)
            kAutoStatus.TextColor3 = RED
            task.wait(3)
            kothHopping = false
        end
    end)
end

-- ============================================================
-- AUTO KOTH LOOP
-- ============================================================
task.spawn(function()
    local wasHolding = false

    local function getKOTHPos()
        local ok, hitbox = pcall(function()
            return workspace:WaitForChild("KOTH", 5):WaitForChild("AreaHitbox", 5)
        end)
        if ok and hitbox then return hitbox.Position + Vector3.new(0, 3, 0) end
        return nil
    end

    while ScreenGui.Parent do
        if forceHop then
            forceHop = false
            hopToLeastPopulated("Force")
            task.wait(5)
        end

        if autoKOTH and not kothHopping then
            local myAura               = getAura()
            local claimed, _, kingAura = getKOTHStatus()
            local inKOTH               = isInKOTH()

            if inKOTH then
                if claimed and kingAura > myAura then
                    wasHolding = false
                    if autoServerHop then
                        kAutoStatus.Text       = "⚠️ Threat! Hopping..."
                        kAutoStatus.TextColor3 = RED
                        hopToLeastPopulated("Threat")
                    else
                        kAutoStatus.Text       = "⚠️ Threat! Staying..."
                        kAutoStatus.TextColor3 = WARN
                    end
                else
                    wasHolding             = true
                    kAutoStatus.Text       = "👑 Holding KOTH!"
                    kAutoStatus.TextColor3 = WHITE
                end
            else
                local KOTH_POS = getKOTHPos()
                if wasHolding then
                    if claimed and kingAura > myAura then
                        wasHolding = false
                        if autoServerHop then
                            kAutoStatus.Text       = "💀 Killed! Hopping..."
                            kAutoStatus.TextColor3 = RED
                            hopToLeastPopulated("Killed")
                            task.wait(5)
                        else
                            kAutoStatus.Text       = "💀 Killed! Checking..."
                            kAutoStatus.TextColor3 = WARN
                            task.wait(2)
                            local claimed2, _, kingAura2 = getKOTHStatus()
                            local myAura2             = getAura()
                            if not claimed2 or myAura2 > kingAura2 then
                                kAutoStatus.Text       = "🔁 Re-entering..."
                                kAutoStatus.TextColor3 = WARN
                                if KOTH_POS then teleport(KOTH_POS) end
                            else
                                kAutoStatus.Text       = "💪 King strong — waiting"
                                kAutoStatus.TextColor3 = RED
                            end
                        end
                    else
                        wasHolding             = false
                        kAutoStatus.Text       = "🔁 Re-entering..."
                        kAutoStatus.TextColor3 = WARN
                        if KOTH_POS then teleport(KOTH_POS) end
                    end
                elseif not claimed then
                    kAutoStatus.Text       = "🟢 Empty — entering!"
                    kAutoStatus.TextColor3 = GREEN
                    if KOTH_POS then teleport(KOTH_POS) end
                elseif myAura > kingAura then
                    kAutoStatus.Text       = "⚡ King weak — entering!"
                    kAutoStatus.TextColor3 = WARN
                    if KOTH_POS then teleport(KOTH_POS) end
                else
                    if autoServerHop then
                        kAutoStatus.Text       = "💪 King strong — hopping!"
                        kAutoStatus.TextColor3 = RED
                        hopToLeastPopulated("Strong King")
                    else
                        kAutoStatus.Text       = "💪 King strong — waiting"
                        kAutoStatus.TextColor3 = RED
                    end
                end
            end
        end
        task.wait(3)
    end
end)

