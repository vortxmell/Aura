-- ─── Popup Logic ─────────────────────────────────────────────────────────────
local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad)

local function refreshPopupItems()
    local aura = getAura()
    for i, item in ipairs(popupItems) do
        local isPast   = aura >= item.area.req
        local isSel    = selectedInPopup == i
        local isCurrent = comboTarget and comboTarget.name == item.area.name

        -- background highlight
        item.frame.BackgroundTransparency = isSel and 0 or 1
        item.frame.BackgroundColor3 = isSel
            and Color3.fromRGB(50, 35, 80)
            or  Color3.fromRGB(25, 20, 38)

        -- dot color
        item.dot.BackgroundColor3 = isSel and PURPLE or (isPast and WARN or DIM)

        -- name color
        item.nameLbl.TextColor3 = isPast and WARN or WHITE

        -- warn icon
        item.warnIcon.Text = isPast and "⚠" or (isCurrent and "✓" or "")
        item.warnIcon.TextColor3 = isPast and WARN or Color3.fromRGB(100, 220, 100)

        -- req label
        item.reqLbl.TextColor3 = isPast and WARN or DIM
    end

    -- warn label bawah
    if selectedInPopup then
        local sel = areas[selectedInPopup]
        if getAura() >= sel.req then
            PopupWarnLabel.Text = "⚠ Aura dah lepas target ni"
        else
            PopupWarnLabel.Text = ""
        end
    else
        PopupWarnLabel.Text = ""
    end
end

local function openPopup()
    -- set selectedInPopup to current comboTarget index
    selectedInPopup = nil
    if comboTarget then
        for i, a in ipairs(areas) do
            if a.name == comboTarget.name then
                selectedInPopup = i
                break
            end
        end
    end
    refreshPopupItems()
    Backdrop.Visible = true
    Popup.Visible = true
end

local function closePopup()
    Backdrop.Visible = false
    Popup.Visible = false
    selectedInPopup = nil
    PopupWarnLabel.Text = ""
end

