    {name = "Fire Bath",     req = 100e6,   pos = Vector3.new(118,  10,  -123)},
    {name = "Dark Lava",     req = 1e15,    pos = Vector3.new(40,   17,  -136)},
    {name = "Ancient Ruins", req = 100e18,  pos = Vector3.new(249,  10,   -80)},
    {name = "Electra Field", req = 100e24,  pos = Vector3.new(72,    9,   104)},
